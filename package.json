{
  "name": "pipefy-api",
  "version": "1.7.1",
  "description": "This library provides a convenient way to interact with the Pipefy API, allowing developers to easily integrate Pipefy functionality into their applications. It includes functions for managing cards, pipes, comments, and more.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && cp src/index.d.ts dist/index.d.ts",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Go-Business-Inc/PipefyAPI.git"
  },
  "keywords": [
    "pipefy",
    "typescript",
    "api",
    "library"
  ],
  "type": "commonjs",
  "author": "Ramón David Sifuentes from Go Business Inc.",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "node-fetch": "^3.0.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  },
  "bugs": {
    "url": "https://github.com/Go-Business-Inc/PipefyAPI/issues"
  },
  "homepage": "https://github.com/Go-Business-Inc/PipefyAPI#readme"
}
